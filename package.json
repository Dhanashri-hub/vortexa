{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"require('fs').existsSync('package-lock.json') && require('fs').unlinkSync('package-lock.json'); require('fs').existsSync('yarn.lock') && require('fs').unlinkSync('yarn.lock');\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.62.0",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@tailwindcss/oxide-win32-x64-msvc": "4.3.0",
    "lightningcss-win32-x64-msvc": "1.32.0"
  }
}
